# ============================================================
# Application
# ============================================================
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================================
# Security
# ============================================================
# 64-character random hex string — generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=REPLACE_WITH_64_CHAR_HEX_SECRET

# ============================================================
# Admin Account (created on first run via setup script)
# ============================================================
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@schule.de
ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ============================================================
# Cloudflare (set in wrangler.toml for local, dashboard for prod)
# ============================================================
# These are bound automatically — no need to set as env vars
# CF_D1_DATABASE_ID=...
# CF_KV_NAMESPACE_ID=...
