{
  "name": "wm-tippspiel",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "pages:build": "npx @cloudflare/next-on-pages",
    "preview": "npm run pages:build && wrangler pages dev",
    "deploy": "npm run pages:build && wrangler pages deploy",
    "db:migrate": "wrangler d1 migrations apply wm-tippspiel-db",
    "db:migrate:prod": "wrangler d1 migrations apply wm-tippspiel-db --remote",
    "db:studio": "wrangler d1 execute wm-tippspiel-db --command 'SELECT 1'"
  },
  "dependencies": {
    "@cloudflare/next-on-pages": "^1.13.7",
    "@marsidev/react-turnstile": "^1.5.2",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "lucide-react": "^0.460.0",
    "next": "15.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.5.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241224.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.20",
    "eslint": "^8",
    "eslint-config-next": "15.1.3",
    "postcss": "^8",
    "tailwindcss": "^3.4.17",
    "typescript": "^5",
    "wrangler": "^3.101.0",
    "xlsx": "^0.18.5"
  },
  "engines": {
    "node": ">=18.17.0"
  }
}
